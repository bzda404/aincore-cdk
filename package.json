{
  "name": "@mindvault/sdk",
  "version": "0.4.0",
  "description": "MindVault Client SDK \u2014 \u5c06\u60a8\u7684\u5e94\u7528\u5feb\u901f\u63a5\u5165 MindVault Core \u672c\u5730 AI \u751f\u6001",
  "license": "MIT",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc",
    "lint": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "keywords": [
    "mindvault",
    "ai",
    "llm",
    "local-ai",
    "mindvault-core",
    "mcp",
    "oauth",
    "pkce"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bzda404/mindvault-sdk.git"
  },
  "homepage": "https://github.com/bzda404/mindvault-sdk#readme",
  "bugs": {
    "url": "https://github.com/bzda404/mindvault-sdk/issues"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
